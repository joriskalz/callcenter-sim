# Public base URL used by ACS callbacks. Use your public HTTPS tunnel/App Service URL outside local dry runs.
PUBLIC_BASE_URL=http://localhost:3000
CALLBACK_PATH=/api/callbacks

# Local sample data.
SCENARIOS_PATH=config/scenarios.sample.json
SAMPLE_CONTACTS_PATH=config/contacts.sample.json
RECENT_EVENT_LIMIT=100

# ACS Call Automation and TTS.
ACS_CONNECTION_STRING=
COGNITIVE_SERVICES_ENDPOINT=
DEFAULT_LOCALE=de-DE
DEFAULT_VOICE_NAME=de-DE-KatjaNeural

# Optional API protection.
MONITOR_API_KEY=
WEBHOOK_SHARED_SECRET=

# Dataverse/Dynamics 365. Leave empty to use sample contacts.
DATAVERSE_URL=
DATAVERSE_TENANT_ID=
DATAVERSE_CLIENT_ID=
DATAVERSE_CLIENT_SECRET=
DATAVERSE_CONTACT_FIELD_PREFIX=new
